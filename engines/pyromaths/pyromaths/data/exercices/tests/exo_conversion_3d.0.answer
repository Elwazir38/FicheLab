\begin{multicols}{2}\noindent
\begin{enumerate}
\item $\SI{96,5}{dam^3}=\SI{96\,500\,000}{dm^3}$\vspace{1ex}\par
\item $\SI{59,8}{dam^3}=\SI{59\,800}{m^3}$\vspace{1ex}\par
\item $\SI{4,67}{dam^3}=\SI{0,004\,67}{hm^3}$\vspace{1ex}\par
\item $\SI{8,74}{dm^3}=\SI{8\,740\,000}{mm^3}$\vspace{1ex}\par
\item $\SI{3,57}{dam^3}=\SI{0,000\,003\,57}{km^3}$\vspace{1ex}\par
\item $\SI{8,48}{m^3}=\SI{8\,480}{dm^3}$\vspace{1ex}\par
\end{enumerate}
